def lookup(fruit_dict, search_term):
    # Normalize search term (case-insensitive)
    search_term = search_term.lower()

    # Find matching keys
    matches = []
    for key in fruit_dict:
        if search_term in key.lower():
            matches.append(key)

    # Handle cases
    if len(matches) == 0:
        raise KeyError("search term not found")
    elif len(matches) > 1:
        raise KeyError("multiple keys found")
    else:
        key = matches[0]
        return key, fruit_dict[key]
