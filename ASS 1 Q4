# Define classes
class Dog:
    def make_sound(self):
        return "Woof 🐶"

class Cat:
    def make_sound(self):
        return "Meow 🐱"


# Function that works with any object having make_sound()
def process_sound(sound_object):
    print(sound_object.make_sound())


# Usage
dog = Dog()
cat = Cat()

process_sound(dog)  # Works with Dog
process_sound(cat)  # Works with Cat
